  -webkit-flex-wrap: wrap;
  -ms-flex-wrap: wrap;
  flex-wrap: wrap; }
  .select-product-img li {
    position: relative;
    margin-right: 5px; }
    .select-product-img li .radio-wrap {
      position: absolute;
      left: 50%;
      top: 30px;
      transform: translate(-50%, -50%);
      opacity: 0;
      visibility: hidden; }
