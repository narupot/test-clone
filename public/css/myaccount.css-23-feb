    .block-list-order .list-header .info-seller .seller-name, .block-list-order .list-header .info-seller .seller-tel {
      color: #707070; }
      .block-list-order .list-header .info-seller .seller-name span, .block-list-order .list-header .info-seller .seller-tel span {
