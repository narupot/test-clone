.wishlist-cont .action-btn {
  display: flex;
  justify-content: space-around; }
  .wishlist-cont .action-btn a, .wishlist-cont .action-btn button {
    min-width: 50px;
    padding-left: 5px;
    padding-right: 5px;
    margin-left: 3px;
    margin-top: 4px; }
.wishlist-cont .action-close {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  -webkit-transform: translateY(-50%);
  opacity: 0;
  visibility: hidden;
  font-size: 18px; }

