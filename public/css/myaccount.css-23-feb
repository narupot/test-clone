      color: #ED1B24; }
.wishlist-cont .action-wrap {
  text-align: right;
  position: relative;
  display: block;
  padding-right: 22px; }
  .wishlist-cont .action-wrap .price-wrap {
    font-size: 20px;
    margin-bottom: 15px; }
    .wishlist-cont .action-wrap .price-wrap .price, .wishlist-cont .action-wrap .price-wrap .ask-price-label {
      font-size: 20px; }
    .wishlist-cont .action-wrap .price-wrap .ask-price-label {
